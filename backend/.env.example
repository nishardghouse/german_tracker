# Copy to .env and fill in. .env is gitignored.
ANTHROPIC_API_KEY=sk-ant-...

# Bearer token that protects the app. Pick any long random string.
# Leave empty to disable auth (local dev only — never empty in production).
APP_TOKEN=

# Comma-separated list of allowed CORS origins.
# In production (FastAPI serves the frontend) this can be left as-is or removed.
CORS_ORIGINS=http://localhost:5173

# Cost/speed-tiered model defaults. Grading is a high-volume structured call (Haiku).
# Conversation is split: a fast streamed REPLY (Haiku) so it responds instantly, and a
# background FEEDBACK pass (Sonnet) for error analysis + drills. Bump any to
# claude-opus-4-8 for maximum quality.
GRADING_MODEL=claude-haiku-4-5
CONVERSATION_REPLY_MODEL=claude-haiku-4-5
CONVERSATION_FEEDBACK_MODEL=claude-sonnet-4-6

# DB path override. Default: backend/german_tracker.db (relative to the backend dir).
# DB_PATH=/opt/sprachheld/data/german_tracker.db
